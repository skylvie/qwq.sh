qwq.sh {
    import common-settings
    import log qwq
    import cf-tls

    root * /srv/qwq.sh

    # Shell scripts
    handle /*.sh {
        rewrite * /sh{uri}
        file_server
    }

    handle {
        file_server
    }

    # Custom 404 page
    handle_errors {
        @404 expression {err.status_code} == 404
        handle @404 {
            rewrite * /404.html
            file_server
        }
    }
}